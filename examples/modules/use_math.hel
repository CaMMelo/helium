// Import a sibling module alongside the standard library.
//
// Build and run from the repository root:
//   ./build/bin/helium -I libs/std/.helium/std/0.1.0 \
//       -L libs/std/.helium/std/0.1.0 -l std examples/modules/use_math.hel -o /tmp/use_math
//   /tmp/use_math

import math;
import std.io

main = () : IO<()> {
    io.println(f"area(2.0) = {math.area(2.0)}");
}
