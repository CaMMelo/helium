# @name update_dependency
# @phase pm
# @expect success
# @command bash -c 'tmp=$(mktemp -d); trap "rm -rf \"$tmp\"" EXIT; hel=$(pwd)/build/bin/hel; "$hel" init "$tmp/pkg" >"$tmp/out.txt" 2>&1; cd "$tmp/pkg" || exit 1; for v in 0.1.0 0.2.0; do mkdir -p ".helium/greet/$v/interface"; printf "module greet;\n" > ".helium/greet/$v/greet.hel"; printf "module greet\n" > ".helium/greet/$v/interface/greet.hei"; cc -c -x c /dev/null -o ".helium/greet/$v/greet.o" 2>/dev/null; done; "$hel" add greet@0.1.0 >>"$tmp/out.txt" 2>&1; grep -q "greet = \"0.1.0\"" Heliumfile || exit 1; "$hel" update greet >>"$tmp/out.txt" 2>&1; rc=$?; cat "$tmp/out.txt"; grep -q "greet = \"0.2.0\"" Heliumfile && grep -q "version = \"0.2.0\"" Heliumfile.lock; rc2=$?; exit $((rc || rc2))'
# @match Updated lock file
