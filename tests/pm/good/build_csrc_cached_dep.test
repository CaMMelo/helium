# @name build_csrc_cached_dep
# @phase pm
# @expect success
# @command bash -c 'tmp=$(mktemp -d); trap "rm -rf \"$tmp\"" EXIT; hel=$(pwd)/build/bin/hel; "$hel" init "$tmp/pkg" >"$tmp/out.txt" 2>&1; (cd "$tmp/pkg" && { rm -f lib/math.hel; mkdir -p .helium/cgreet/1.0.0; printf "module cgreet;\n\nforeign greeting : fn() -> str;\n" > .helium/cgreet/1.0.0/cgreet.hel; printf "module cgreet\ngreeting : fn() -> str\n" > .helium/cgreet/1.0.0/cgreet.hei; printf "const char *cgreet_greeting(void)\n{\n\treturn \"Hello from cached C\";\n}\n" > csrc_tmp.c; cc -std=c11 -O2 -c csrc_tmp.c -o csrc_tmp.o && ar rcs .helium/cgreet/1.0.0/libcgreet.a csrc_tmp.o && cc -c -x c /dev/null -o .helium/cgreet/1.0.0/cgreet.o && rm -f csrc_tmp.c csrc_tmp.o && printf "[package]\nname = \"pkg\"\nversion = \"0.1.0\"\nedition = \"2025\"\n\n[dependencies]\ncgreet = \"1.0.0\"\n" > Heliumfile && printf "[package]\nname = \"pkg\"\nversion = \"0.1.0\"\nedition = \"2025\"\n\n[[dependencies]]\nname = \"cgreet\"\nversion = \"1.0.0\"\nchecksum = \"0000000000000000\"\n" > Heliumfile.lock && printf "import cgreet\n\nforeign io_prints : fn(str) -> IO<()>;\n\nmain = () : IO<()> {\n    io_prints(cgreet.greeting())\n}\n" > src/main.hel && "$hel" build && "$hel" run; }) >>"$tmp/out.txt" 2>&1; rc=$?; cat "$tmp/out.txt"; exit $rc'
# @match Hello from cached C
