# @name build_cached_dep
# @phase pm
# @expect success
# @command bash -c 'tmp=$(mktemp -d); trap "rm -rf \"$tmp\"" EXIT; hel=$(pwd)/build/bin/hel; "$hel" init "$tmp/pkg" >"$tmp/out.txt" 2>&1; (cd "$tmp/pkg" && { rm -f lib/math.hel; mkdir -p .helium/math/1.0.0; printf "module math;\n\nadd = (a: i32, b: i32): i32 { a + b };\n" > .helium/math/1.0.0/math.hel; printf "[package]\nname = \"pkg\"\nversion = \"0.1.0\"\nedition = \"2025\"\n\n[dependencies]\nmath = \"1.0.0\"\n" > Heliumfile; printf "[package]\nname = \"pkg\"\nversion = \"0.1.0\"\nedition = \"2025\"\n\n[[dependencies]]\nname = \"math\"\nversion = \"1.0.0\"\nchecksum = \"0000000000000000\"\n" > Heliumfile.lock; printf "import std.io\nimport math\n\nmain = () : IO<()> {\n    io.print_int(math.add(2, 3));\n    io.println(\"\");\n}\n" > src/main.hel; "$hel" build; "$hel" run; }) >>"$tmp/out.txt" 2>&1; rc=$?; cat "$tmp/out.txt"; exit $rc'
# @match 5
