module list;

/*
 * Arrays are the list-like aggregate in this bootstrap.  Generic map/filter/fold
 * are deferred because they need dynamic allocation (map/filter) or element
 * access (fold) not yet exposed to library code through the FFI.
 *
 * The demonstration below provides length for empty i32 arrays.  The runtime
 * helper works for any array, but the bootstrap type system requires the size
 * to be explicit in the foreign declaration.
 */
foreign length : fn([i32; 0]) -> i32;
